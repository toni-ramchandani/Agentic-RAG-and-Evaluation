# .env file for Agentic RAG and Evaluation
# This file contains configuration settings for the application

# LLM Provider - choose between 'ollama' or 'openai'
LLM_PROVIDER=ollama

# For OpenAI Vector Store (if using OpenAI)
# OPENAI_API_KEY=your_openai_api_key_here

# For ChromaDB (local vector store)
USE_LOCAL_VECTOR_STORE=true
CHROMA_PERSIST_DIR=./chroma_db

# For Ollama
OLLAMA_MODEL=qwen3-coder:30b
OLLAMA_BASE_URL=http://localhost:11434

# For OpenAI (if using OpenAI)
# OPENAI_MODEL=gpt-3.5-turbo